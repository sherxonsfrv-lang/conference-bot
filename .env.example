# ============================================
# Conference Networking Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# Required Configuration
# ============================================

# Telegram Bot Token
# Get it from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=token

# MySQL Database Configuration
DB_NAME=social_connection_bot
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_DIALECT=mysql

# Second Screen API Key
# Generate a strong random string for securing second screen endpoints
# This key is required for accessing second screen REST API and Socket.IO
# Example: openssl rand -hex 32
SECOND_SCREEN_API_KEY=Second-screen-key

# Main Admin Telegram IDs
# Comma-separated list of Telegram user IDs who have main admin privileges
# You can get your Telegram ID from @userinfobot
MAIN_ADMIN_TELEGRAM_IDS=telegram_id

# Database Encryption Key
# Generate a strong 32-character key for user personal data encryption
# Example: openssl rand -hex 16
DB_ENCRYPTION_KEY=your-32-char-encryption-key-here

# JWT Secret Key
# Secret key for signing Telegram Web App user JWT session tokens
# Example: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here

# ============================================
# Optional Configuration
# ============================================

# Server Port
# Default: 3000
PORT=3000

# Base URL for Second Screen Links
# Used when generating second screen URLs in bot messages
# Use BASE_URL or SERVER_URL (BASE_URL takes precedence)
# Examples:
#   - Development: http://localhost:3000
#   - Production: https://yourdomain.com
BASE_URL=http://localhost:3000
# SERVER_URL=http://localhost:3000

# Node Environment
# Options: development, staging, production
# Default: development
NODE_ENV=development
